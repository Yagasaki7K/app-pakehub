# Node.js version used by the GitHub Actions workflow and local Pake builds.
NODE_VERSION=24

# Web application URL that Pake wraps into native desktop installers.
APP_URL=https://discord.com

# Repository-root directory that stores only final generated installers and application bundles.
PROJECTS_DIR=projects

# Repository-root directory used for temporary build output, diagnostics, and GitHub Actions artifact transfer.
ARTIFACTS_DIR=artifacts

# GitHub token used by release automation when running in GitHub Actions.
# Keep this empty in the repository and provide the real token only through GitHub Actions secrets.
GITHUB_TOKEN=
